+#ifdef __EMSCRIPTEN__
+	// ===================== PS2WEB(JIT-04 v2): REGION COMPILATION =====================
+	// A block must be executable the moment it is first dispatched, so we cannot buffer blocks
+	// and compile them later. But we CAN compile MORE of them right now: on a miss, walk the
+	// region reachable from this address (fall-through + direct branch targets) and compile up to
+	// PS2WEB_REGION_SIZE blocks into a SINGLE wasm module.
+	//
+	// Why this and not the previous tiered design: that one still created one module per block and
+	// only released them once the GC got around to it, so it allocated ~2x and died inside
+	// WasmCreateBatchModule during a real game's compile avalanche ("failed to allocate executable
+	// memory"). Here there is no solo tier, nothing to release, and no dependence on the GC —
+	// module count drops ~K-fold at the moment of allocation, which is where the game actually dies.
+	static const uint32 PS2WEB_REGION_SIZE = 32;
+
+	// PS2WEB(JIT-04 v2): cheap checksum of a block's source instructions. Used to detect that a
+	// SPECULATIVELY-compiled block was compiled from memory that has since changed (DMA/SMC).
+	uint32 Ps2webSourceSum(uint32 startAddress, uint32 endAddress)
+	{
+		uint32 sum = 2166136261u; //FNV-1a
+		for(uint32 address = startAddress; address <= endAddress; address += 4)
+		{
+			uint32 opcode = m_context.m_pMemoryMap->GetInstruction(address);
+			sum = (sum ^ opcode) * 16777619u;
+		}
+		return sum | 1u; //never 0: 0 means "not speculative / already verified"
+	}
+
+	// Called on a block right before it executes. If the block was compiled speculatively (ahead of
+	// its first real execution), re-check its source against memory now that the game may have loaded
+	// the real code. On mismatch, invalidate and recompile fresh — this is what stops a commercial
+	// game from running garbage that was pre-compiled from not-yet-loaded memory (black screen at
+	// 24fps: it runs, but wrong). On match, clear the flag: verified once, never checked again.
+	CBasicBlock* Ps2webVerifyBlock(uint32 address, CBasicBlock* block)
+	{
+		uint32 expected = block->Ps2webSpecSum();
+		if(expected == 0) return block; //on-demand or already verified: hot path, one field read
+		uint32 actual = Ps2webSourceSum(block->GetBeginAddress(), block->GetEndAddress());
+		if(actual == expected)
+		{
+			block->Ps2webSetSpecSum(0); //stable: don't check again
+			return block;
+		}
+		//Stale: the code at this address changed since we speculated it. Invalidate and recompile.
+		g_ps2webStaleReverts.fetch_add(1, std::memory_order_relaxed);
+		ClearActiveBlocksInRangeInternal(block->GetBeginAddress(), block->GetEndAddress(), nullptr);
+		PartitionFunction(address);
+		auto fresh = m_blockLookup.FindBlockAt(address);
+		return fresh;
+	}
+
+	void Ps2webPartitionRegion(uint32 startAddress)
+	{
+		struct REGION_BLOCK { uint32 start; uint32 end; uint32 branch; };
+		std::vector<REGION_BLOCK> region;
+		std::vector<uint32> worklist;
+		std::set<uint32> seen;
+		worklist.push_back(startAddress);
+
+		while(!worklist.empty() && (region.size() < PS2WEB_REGION_SIZE))
+		{
+			uint32 address = worklist.front();
+			worklist.erase(worklist.begin()); //breadth-first: stay close to the hot path
+			if(address == MIPS_INVALID_PC) continue;
+			if((address & 0x3) != 0) continue;          //never speculate on unaligned garbage
+			if(address > m_maxAddress) continue;
+			if(!seen.insert(address).second) continue;
+			if(!FindBlockStartingAt(address)->IsEmpty()) continue; //already compiled
+
+			uint32 endAddress = MIPS_INVALID_PC;
+			uint32 branchAddress = MIPS_INVALID_PC;
+			Ps2webScanBlock(address, endAddress, branchAddress);
+			if((endAddress - address) > MAX_BLOCK_SIZE) continue;
+			if(endAddress > m_maxAddress) continue;
+
+			region.push_back({address, endAddress, branchAddress});
+			worklist.push_back((endAddress + 4) & m_addressMask); //fall-through
+			if(branchAddress != MIPS_INVALID_PC)
+			{
+				worklist.push_back(branchAddress & m_addressMask); //direct branch target
+			}
+		}
+
+		if(region.empty()) return;
+
+		//Compile every block of the region WITHOUT allocating a module for any of them.
+		g_ps2webDeferModule = true;
+		for(const auto& regionBlock : region)
+		{
+			CreateBlock(regionBlock.start, regionBlock.end);
+		}
+		g_ps2webDeferModule = false;
+
+		//Collect the blocks that actually need a function (a cached/dedup'd block already has one).
+		std::vector<CBasicBlock*> pending;
+		for(const auto& regionBlock : region)
+		{
+			auto block = FindBlockStartingAt(regionBlock.start);
+			if(block->IsEmpty()) continue;
+			if(block->Ps2webGetModuleBytes().empty()) continue; //dedup'd: shares another module
+			if(block->GetWasmTableIndex() != 0) continue;       //already has a function
+			pending.push_back(block);
+		}
+
+		Ps2webMaterializeRegion(pending);
+
+		//Every block of the region is executable now: register it in BOTH dispatch maps. This must
+		//cover dedup'd blocks too (they never pass through the materializer, since they already
+		//carry a function copied from another block) or they would be missing from the map.
+		for(const auto& regionBlock : region)
+		{
+			auto block = FindBlockStartingAt(regionBlock.start);
+			if(block->IsEmpty()) continue;
+			uint32 tableIndex = block->GetWasmTableIndex();
+			if(tableIndex != 0)
+			{
+				ps2webExecInsert(regionBlock.start, tableIndex);
+				std::lock_guard<std::mutex> _l(g_ps2webChainMapMtx);
+				g_ps2webChainMap[regionBlock.start] = tableIndex;
+				ps2webChainInsert(regionBlock.start, tableIndex);
+			}
+			if(block->GetRecycleCount() < RECYCLE_NOLINK_THRESHOLD)
+			{
+				SetupBlockLinks(regionBlock.start, regionBlock.end, regionBlock.branch);
+			}
+			// Everything except the demanded block was compiled AHEAD of execution: mark it
+			// speculative so its first real dispatch re-checks the source against memory.
+			if(regionBlock.start != startAddress)
+			{
+				block->Ps2webSetSpecSum(Ps2webSourceSum(regionBlock.start, regionBlock.end));
+			}
+		}
+	}
+
+	//Fold N compiled-but-module-less blocks into ONE wasm module and hand each its function.
+	void Ps2webMaterializeRegion(const std::vector<CBasicBlock*>& pending)
+	{
+		if(pending.empty()) return;
+
+		std::vector<CBasicBlock*> folded;
+		if(pending.size() >= 2)
+		{
+			CWasmModuleBuilder builder;
+			Jitter::CWasmFunctionRegistry::AddCanonicalFunctionTypes(builder);
+			for(auto* block : pending)
+			{
+				CWasmModuleBuilder::FunctionCode body;
+				const auto& moduleBytes = block->Ps2webGetModuleBytes();
+				if(!CWasmModuleBuilder::ExtractSingleFunctionBody(
+				       moduleBytes.data(), static_cast<uint32>(moduleBytes.size()), body))
+				{
+					g_ps2webBatchSkipped.fetch_add(1, std::memory_order_relaxed);
+					continue;
+				}
+				builder.AddRawFunctionBody(std::move(body));
+				folded.push_back(block);
+			}
+
+			if(folded.size() >= 2)
+			{
+				Framework::CMemStream stream;
+				builder.WriteModule(stream);
+				auto functions = CMemoryFunction::CreateBatch(stream.GetBuffer(), stream.GetSize(),
+				                                              static_cast<uint32>(folded.size()));
+				if(functions.size() == folded.size())
+				{
+					for(uint32 i = 0; i < folded.size(); i++)
+					{
+						Ps2webGiveFunction(folded[i], std::move(functions[i]));
+					}
+					return;
+				}
+				//Region module failed (e.g. out of executable memory): fall through to solo.
+				g_ps2webRegionFallbacks.fetch_add(1, std::memory_order_relaxed);
+			}
+		}
+
+		//Fallback / single-block region: give each block its own module, upstream-style. A block
+		//with no function would be a guaranteed trap, so this path must never be skipped.
+		for(auto* block : pending)
+		{
+			if(block->GetWasmTableIndex() != 0) continue;
+			const auto& moduleBytes = block->Ps2webGetModuleBytes();
+			if(moduleBytes.empty()) continue;
+			Ps2webGiveFunction(block, CMemoryFunction(moduleBytes.data(), moduleBytes.size()));
+		}
+	}
+
+	void Ps2webGiveFunction(CBasicBlock* block, CMemoryFunction&& function)
+	{
+		block->Ps2webRepoint(std::move(function));
+	}
+	// ================================================================================
+#endif
