+	// ===================== PS2WEB(JIT-04): tiered re-batching =====================
+	// Tier 1: a block is compiled into its OWN module (upstream behaviour) so it is executable
+	// on first dispatch — Play! compiles lazily, we cannot wait to fill a batch.
+	// Tier 2: once PS2WEB_BATCH_SIZE blocks pile up, re-emit their function bodies as ONE module,
+	// re-point each block at it, and drop the solo modules. The engine then reclaims their
+	// code-space (measured: ~18.9 KB per module — docs/JIT-04-BATCHING.md).
+	static const uint32 PS2WEB_BATCH_SIZE = 32;
+
+	void ps2webBatchEnqueue(const BasicBlockPtr& block)
+	{
+		if(block->Ps2webGetModuleBytes().empty()) return; //dedup'd block: shares another module
+		m_ps2webPending.push_back(block);
+		if(m_ps2webPending.size() >= PS2WEB_BATCH_SIZE) ps2webBatchFlush();
+	}
+
+	void ps2webBatchFlush()
+	{
+		auto pending = std::move(m_ps2webPending);
+		m_ps2webPending.clear();
+		if(pending.size() < 2)
+		{
+			for(auto& weakBlock : pending)
+			{
+				if(auto block = weakBlock.lock()) block->Ps2webClearModuleBytes();
+			}
+			return;
+		}
+
+		CWasmModuleBuilder builder;
+		Jitter::CWasmFunctionRegistry::AddCanonicalFunctionTypes(builder);
+
+		std::vector<BasicBlockPtr> batched;
+		batched.reserve(pending.size());
+
+		for(auto& weakBlock : pending)
+		{
+			auto block = weakBlock.lock();
+			//Guard 1: the block was invalidated/recycled while pending -> drop it. Re-pointing a
+			//dead block would resurrect a stale PC->index entry (HANDOFF §3 #4).
+			if(!block) { g_ps2webBatchSkipped.fetch_add(1, std::memory_order_relaxed); continue; }
+			//Guard 2: this PC no longer resolves to THIS block (SMC replaced it) -> drop it.
+			if(m_blockLookup.FindBlockAt(block->GetBeginAddress()) != block.get())
+			{
+				block->Ps2webClearModuleBytes();
+				g_ps2webBatchSkipped.fetch_add(1, std::memory_order_relaxed);
+				continue;
+			}
+			CWasmModuleBuilder::FunctionCode body;
+			const auto& moduleBytes = block->Ps2webGetModuleBytes();
+			if(moduleBytes.empty() ||
+			   !CWasmModuleBuilder::ExtractSingleFunctionBody(moduleBytes.data(),
+			                                                  static_cast<uint32>(moduleBytes.size()), body))
+			{
+				block->Ps2webClearModuleBytes();
+				g_ps2webBatchSkipped.fetch_add(1, std::memory_order_relaxed);
+				continue;
+			}
+			builder.AddRawFunctionBody(std::move(body));
+			batched.push_back(block);
+		}
+
+		if(batched.size() < 2)
+		{
+			for(auto& block : batched) block->Ps2webClearModuleBytes();
+			return;
+		}
+
+		Framework::CMemStream stream;
+		builder.WriteModule(stream);
+
+		auto functions = CMemoryFunction::CreateBatch(stream.GetBuffer(), stream.GetSize(),
+		                                              static_cast<uint32>(batched.size()));
+		assert(functions.size() == batched.size());
+
+		for(uint32 i = 0; i < batched.size(); i++)
+		{
+			auto& block = batched[i];
+			block->Ps2webRepoint(std::move(functions[i])); //drops the solo module
+			uint32 pc = block->GetBeginAddress();
+			uint32 tableIndex = block->GetWasmTableIndex();
+			//Both maps MUST follow the block to its new table index, or the harness audits
+			//(execMismatches / chainTableMismatches) go non-zero and the gate fails.
+			ps2webExecInsert(pc, tableIndex);
+			{
+				std::lock_guard<std::mutex> _l(g_ps2webChainMapMtx);
+				g_ps2webChainMap[pc] = tableIndex;
+				ps2webChainInsert(pc, tableIndex);
+			}
+		}
+	}
+
